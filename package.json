{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "concurrently -n VITE,BRIDGE \"vite --host 127.0.0.1\" \"cmd /c fingerprint-bridge\\run-bridge.bat\"",
        "dev:vite": "vite --host 127.0.0.1",
        "dev:bridge": "cmd /c fingerprint-bridge\\run-bridge.bat"
    },
    "devDependencies": {
        "@popperjs/core": "^2.11.8",
        "axios": "^1.18.1",
        "bootstrap": "^5.3.8",
        "concurrently": "^10.0.3",
        "esbuild": "^0.28.1",
        "laravel-vite-plugin": "^3.1.0",
        "sass": "^1.101.0",
        "vite": "^8.1.2"
    },
    "allowScripts": {
        "@parcel/watcher@2.5.6": true,
        "esbuild@0.28.1": true
    }
}
